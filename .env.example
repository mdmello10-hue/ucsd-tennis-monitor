# UCSD Recreation Public Access login.
# This monitor targets the Public Access username/password flow, not UCSD SSO.
UCSD_REC_USERNAME=your-public-access-email@example.com
UCSD_REC_PASSWORD=your-public-access-password

# Gmail SMTP alert delivery.
# For Gmail, create an app password and use it here.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
ALERT_TO=destination-address@example.com

# Google Calendar filtering.
# Comma-separated calendar ids. "primary" is the default calendar.
GOOGLE_CALENDAR_IDS=primary

# Polling window and timezone.
POLL_DAYS=3
TIMEZONE=America/Los_Angeles

# Optional paths.
STATE_DB_PATH=.ucsd-tennis-monitor/state.sqlite3
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=.ucsd-tennis-monitor/google-token.json
UCSD_STORAGE_STATE_PATH=.ucsd-tennis-monitor/ucsd-storage-state.json

# Set to false only when you need to debug login visually.
UCSD_HEADLESS=true
